#!/usr/bin/env python3
"""Image-to-video generation with the official Wan2.2 TI2V 5B model."""

import argparse
import time
from pathlib import Path

import torch
from diffusers import WanImageToVideoPipeline
from diffusers.utils import export_to_video, load_image


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("prompt")
    parser.add_argument("--i2v", required=True)
    parser.add_argument("--duration", type=float, default=3.0)
    parser.add_argument("--res", default="832x480")
    parser.add_argument("--label", default="wan")
    parser.add_argument("--fps", type=int, default=16)
    parser.add_argument("--steps", type=int, default=20)
    parser.add_argument("--seed", type=int, default=42)
    args = parser.parse_args()

    root = Path(__file__).resolve().parent.parent
    model = root / "models" / "wan2.2-ti2v-5b"
    if not (model / "model_index.json").exists():
        raise SystemExit(f"Wan model missing: {model}; run bin/setup-local")

    width, height = (int(v) for v in args.res.lower().split("x"))
    width = max(256, width // 32 * 32)
    height = max(256, height // 32 * 32)
    frames = max(5, int(args.duration * args.fps))
    frames = ((frames - 1) // 4) * 4 + 1

    pipe = WanImageToVideoPipeline.from_pretrained(
        model, torch_dtype=torch.bfloat16, local_files_only=True
    ).to("mps")
    image = load_image(args.i2v).resize((width, height))
    generator = torch.Generator(device="cpu").manual_seed(args.seed)
    result = pipe(
        image=image,
        prompt=args.prompt,
        negative_prompt=("blurry, distorted, low quality, static, subtitles, "
                         "deformed, artifacts"),
        height=height,
        width=width,
        num_frames=frames,
        num_inference_steps=args.steps,
        guidance_scale=5.0,
        generator=generator,
    ).frames[0]
    out_dir = root / "outputs"
    out_dir.mkdir(parents=True, exist_ok=True)
    out = out_dir / f"{args.label}_wan5b_{int(time.time())}.mp4"
    export_to_video(result, str(out), fps=args.fps)
    print(f"[wan] done -> {out}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
